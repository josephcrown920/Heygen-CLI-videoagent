# HeyGen Studio — Environment Variables
# Copy this file and add your secrets via Replit Secrets (never commit real keys)

# ─── REQUIRED ───────────────────────────────────────────────────────────────

# fal.ai API key — get from https://fal.ai/dashboard/keys
# Used by: POST /api/fal/submit, GET /api/fal/status (Kling, Seedance, FLUX)
FAL_API_KEY=

# OpenAI API key — get from https://platform.openai.com/api-keys
# Used by: POST /api/si/plan (SI Director GPT-4o JSON mode)
OPENAI_API_KEY=

# HuggingFace read token — get from https://hf.co/settings/tokens
# Used by: POST /api/hf/text, /api/hf/image, /api/hf/embed (inference API)
HUGGINGFACE_TOKEN=

# ─── AUTO-SET BY REPLIT ─────────────────────────────────────────────────────

# Port — assigned automatically per artifact, do not hardcode
# PORT=

# Database URL — set if using PostgreSQL (Replit DB integration)
# DATABASE_URL=
